name: wine-quality-ci

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      n_estimators: {type: int, default: 100}
      max_depth: {type: int, default: 10}
      min_samples_split: {type: int, default: 5}
      data_dir: {type: str, default: "wine_quality_preprocessing"}
      model_output: {type: str, default: "artifacts/model"}
    command: >
      python modelling.py
      --n_estimators {n_estimators}
      --max_depth {max_depth}
      --min_samples_split {min_samples_split}
      --data_dir {data_dir}
      --model_output {model_output}
